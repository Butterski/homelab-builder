# HLBuilder self-hosted Docker config

# Use "latest" for the newest published image, or pin a release tag when one exists.
HLBUILDER_IMAGE=butterski/homelab-builder
HLBUILDER_TAG=latest

# Local web port. Open http://localhost:3000 after startup.
FRONTEND_PORT=3000

# Database settings for the bundled Postgres container.
# Keep DB_HOST=postgres when using the included docker-compose.yml.
# If you run the app container separately, DB_HOST must be the hostname/IP of
# a reachable PostgreSQL container or server on the same Docker network.
DB_HOST=postgres
DB_PORT=5432
DB_USER=homelab
DB_NAME=homelab_builder
DB_PASSWORD=homelab_password
DB_SSLMODE=disable

# Local/trusted-network mode. Leave GOOGLE_CLIENT_ID empty to enable local admin login.
GIN_MODE=debug
GOOGLE_CLIENT_ID=
JWT_SECRET=

TZ=Europe/Berlin
